ARG BASE_IMAGE=ollama/ollama
FROM ${BASE_IMAGE}

# Install curl to preload models
RUN rm -f /etc/apt/sources.list.d/nvshmem* \
          /etc/apt/sources.list.d/cuda* \
          /etc/apt/sources.list.d/*ports* \
    && sed -i '/ports.ubuntu.com/d' /etc/apt/sources.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends curl \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Copy entrypoint script into the image
COPY scripts/ollama-entrypoint.sh /scripts/entrypoint.sh
RUN chmod +x /scripts/entrypoint.sh
