<?xml version="1.0" encoding="utf-8"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="mesh_path" value="file://$(find frida_description)/urdf/meshes/newFRIDA/" />

  <xacro:macro name="load_gripper" params="attach_to:='' xyz:='0 0 0' rpy:='0 0 0'">
    <xacro:unless value="${attach_to == ''}">
      <joint name="gripper_fix" type="fixed">
        <parent link="${attach_to}"/>
        <child link="base_gripper"/>
        <origin xyz="${xyz}" rpy="${rpy}"/>
      </joint>
    </xacro:unless>

  <link name="base_gripper">
    <inertial>
      <origin xyz="-0.00085628 -0.0029871 0.044601" rpy="0 0 0" />
      <mass value="0.640" />
      <inertia ixx="0.00043299" ixy="6.1583E-06" ixz="-5.9911E-06"
               iyy="0.0017661" iyz="4.3683E-05" izz="0.0019355" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${mesh_path}base_gripper.STL" />
      </geometry>
      <material name="">
        <color rgba="1 1 1 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${mesh_path}base_gripper.STL" />
      </geometry>
    </collision>
  </link>
  
  <link name="rightFinger">
    <inertial>
      <origin xyz="0.002185 2.1087E-05 0.039391" rpy="0 0 0" />
      <mass value="0.056899" />
      <inertia ixx="4.3935E-05" ixy="2.9221E-09" ixz="-7.6085E-07"
               iyy="3.4507E-05" iyz="-2.9477E-08" izz="1.1355E-05" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${mesh_path}rightFinger.STL" />
      </geometry>
      <material name="">
        <color rgba="1 1 1 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${mesh_path}rightFinger.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="right_finger" type="prismatic">
    <origin xyz="-0.069107 0.002 0.0785" rpy="0 0 0" />
    <parent link="base_gripper" />
    <child link="rightFinger" />
    <axis xyz="1 0 0" />
    <limit lower="0" upper="0.057" 
          effort="100" velocity="100" />
  </joint>

  <link name="leftFinger">
    <inertial>
      <origin xyz="-0.002185 -2.1087E-05 0.039391" rpy="0 0 0" />
      <mass value="0.056899" />
      <inertia
        ixx="4.3935E-05"
        ixy="2.9221E-09"
        ixz="7.6085E-07"
        iyy="3.4507E-05"
        iyz="2.9477E-08"
        izz="1.1355E-05" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${mesh_path}leftFinger.STL" />
      </geometry>
      <material name="">
        <color rgba="1 1 1 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="${mesh_path}leftFinger.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="left_finger" type="prismatic">
    <origin xyz="0.069107 0.002 0.0785" rpy="0 0 0" />
    <parent link="base_gripper" />
    <child link="leftFinger" />
    <axis xyz="1 0 0" />
    <limit lower="0" upper="0.057"
           effort="100" velocity="100" />
    <mimic
      joint="right_finger"
      multiplier="-1"
      offset="0" />
  </joint>

</xacro:macro>

</robot>