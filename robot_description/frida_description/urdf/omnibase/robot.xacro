<?xml version="1.0"?>
<robot name="home_base" xmlns:xacro="http://ros.org/wiki/xacro">
  <xacro:property name="black_rgba" value="0.102 0.102 0.102 1" />

  <!-- Launch arguments -->
  <xacro:arg name="use_sim_time" default="false"/>
  <xacro:arg name="robot_type" default="real"/>

  <xacro:property name="use_sim_time" value="$(arg use_sim_time)"/>
  <xacro:property name="mesh_dir" value="file://$(find frida_description)/urdf/meshes/omnibase"/>

  <!-- Conditionally include simulation files -->
  <xacro:if value="${use_sim_time}">
    <xacro:include filename="home_base_ros2_control.xacro"/>
  </xacro:if>

  <material name="home_base_gray">
    <color rgba="0.752941176470588 0.752941176470588 0.752941176470588 1"/>
  </material>
  <material name="home_base_lidar">
    <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1"/>
  </material>

  <!-- =================== base_footprint (root) =================== -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <origin xyz="0 0 0.0385" rpy="0 0 0"/>
    <parent link="base_footprint"/>
    <child link="base_link"/>
  </joint>

  <!-- =================== base_link =================== -->
  <link name="base_link">
    <inertial>
      <origin xyz="0.0035289 4.9532E-05 0.18881" rpy="0 0 0"/>
      <mass value="31.284"/>
      <inertia ixx="0.16472" ixy="6.3557E-05" ixz="0.00075615"
               iyy="0.12042" iyz="-0.0002185" izz="0.20341"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_dir}/base_link.STL"/>
      </geometry>
      <material name="home_base_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <!-- decimated collision mesh (~3.9k tris) to avoid MoveIt/FCL
             "too many vertices in collision geometry" on the 430k visual mesh -->
        <mesh filename="${mesh_dir}/base_link_collision.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- =================== wheel_FL =================== -->
  <link name="wheel_FL">
    <inertial>
      <origin xyz="-2.01760275153617E-11 -1.2648801422932E-08 -0.000225751978378957" rpy="0 0 0"/>
      <mass value="0.316522165409144"/>
      <inertia ixx="0.00018550184297716" ixy="1.47011741018487E-13" ixz="2.37351682170515E-11"
               iyy="0.000185501841925862" iyz="3.06630872791257E-11" izz="0.000329540832812286"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_dir}/wheel.STL"/>
      </geometry>
      <material name="home_base_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <!-- cylinder collision mesh (~190 tris) replacing the 264k visual mesh -->
        <mesh filename="${mesh_dir}/wheel_collision.stl"/>
      </geometry>
    </collision>
  </link>
  <xacro:if value="${use_sim_time}">
    <joint name="wheel_FL_joint" type="continuous">
      <origin xyz="0.184790699909997 0.219394995052441 0.0376959841787657" rpy="-1.5707963267949 0 0"/>
      <parent link="base_link"/>
      <child link="wheel_FL"/>
      <axis xyz="0 0 1"/>
    </joint>
  </xacro:if>
  <xacro:unless value="${use_sim_time}">
    <joint name="wheel_FL_joint" type="fixed">
      <origin xyz="0.184790699909997 0.219394995052441 0.0376959841787657" rpy="-1.5707963267949 0 0"/>
      <parent link="base_link"/>
      <child link="wheel_FL"/>
    </joint>
  </xacro:unless>

  <!-- =================== wheel_FR =================== -->
  <link name="wheel_FR">
    <inertial>
      <origin xyz="1.08346649985158E-08 2.62530414074647E-09 -0.000243946115891319" rpy="0 0 0"/>
      <mass value="0.316802369656036"/>
      <inertia ixx="0.000185524626213339" ixy="3.28960054383515E-11" ixz="-3.31069057136383E-11"
               iyy="0.000185524577692034" iyz="1.46274884608806E-10" izz="0.000329541494389925"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_dir}/wheel.STL"/>
      </geometry>
      <material name="home_base_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <!-- cylinder collision mesh (~190 tris) replacing the 264k visual mesh -->
        <mesh filename="${mesh_dir}/wheel_collision.stl"/>
      </geometry>
    </collision>
  </link>
  <xacro:if value="${use_sim_time}">
    <joint name="wheel_FR_joint" type="continuous">
      <origin xyz="0.184790699909996 -0.219395004947559 0.0376959841787653" rpy="-1.5707963267949 0 0"/>
      <parent link="base_link"/>
      <child link="wheel_FR"/>
      <axis xyz="0 0 1"/>
    </joint>
  </xacro:if>
  <xacro:unless value="${use_sim_time}">
    <joint name="wheel_FR_joint" type="fixed">
      <origin xyz="0.184790699909996 -0.219395004947559 0.0376959841787653" rpy="-1.5707963267949 0 0"/>
      <parent link="base_link"/>
      <child link="wheel_FR"/>
    </joint>
  </xacro:unless>

  <!-- =================== wheel_RL =================== -->
  <link name="wheel_RL">
    <inertial>
      <origin xyz="6.27955468179842E-09 -8.84368271322766E-09 -0.000243945799877326" rpy="0 0 0"/>
      <mass value="0.316802379932942"/>
      <inertia ixx="0.000185524613388858" ixy="-3.95566165674954E-11" ixz="1.17507787929333E-10"
               iyy="0.000185524592122908" iyz="9.32696147810741E-11" izz="0.000329541494439521"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_dir}/wheel.STL"/>
      </geometry>
      <material name="home_base_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <!-- cylinder collision mesh (~190 tris) replacing the 264k visual mesh -->
        <mesh filename="${mesh_dir}/wheel_collision.stl"/>
      </geometry>
    </collision>
  </link>
  <xacro:if value="${use_sim_time}">
    <joint name="wheel_RL_joint" type="continuous">
      <origin xyz="-0.184790699909991 0.219394995052441 0.0376959841787652" rpy="-1.5707963267949 0 0"/>
      <parent link="base_link"/>
      <child link="wheel_RL"/>
      <axis xyz="0 0 1"/>
    </joint>
  </xacro:if>
  <xacro:unless value="${use_sim_time}">
    <joint name="wheel_RL_joint" type="fixed">
      <origin xyz="-0.184790699909991 0.219394995052441 0.0376959841787652" rpy="-1.5707963267949 0 0"/>
      <parent link="base_link"/>
      <child link="wheel_RL"/>
    </joint>
  </xacro:unless>

  <!-- =================== wheel_RR =================== -->
  <link name="wheel_RR">
    <inertial>
      <origin xyz="1.54742141322828E-09 1.26432938458987E-08 -0.000225751989580358" rpy="0 0 0"/>
      <mass value="0.316522156157189"/>
      <inertia ixx="0.000185501841998064" ixy="-9.89385955526853E-15" ixz="-2.625503122693E-11"
               iyy="0.00018550184097349" iyz="-2.87014788963402E-11" izz="0.000329540832766985"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_dir}/wheel.STL"/>
      </geometry>
      <material name="home_base_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <!-- cylinder collision mesh (~190 tris) replacing the 264k visual mesh -->
        <mesh filename="${mesh_dir}/wheel_collision.stl"/>
      </geometry>
    </collision>
  </link>
  <xacro:if value="${use_sim_time}">
    <joint name="wheel_RR_joint" type="continuous">
      <origin xyz="-0.184790699909991 -0.219395004947559 0.0376959841787661" rpy="-1.5707963267949 0 0"/>
      <parent link="base_link"/>
      <child link="wheel_RR"/>
      <axis xyz="0 0 1"/>
    </joint>
  </xacro:if>
  <xacro:unless value="${use_sim_time}">
    <joint name="wheel_RR_joint" type="fixed">
      <origin xyz="-0.184790699909991 -0.219395004947559 0.0376959841787661" rpy="-1.5707963267949 0 0"/>
      <parent link="base_link"/>
      <child link="wheel_RR"/>
    </joint>
  </xacro:unless>

  <!-- =================== lidar_front =================== -->
  <link name="lidar_front">
    <inertial>
      <origin xyz="-0.000159118177998852 3.36756577745678E-06 -0.00515345431268351" rpy="0 0 0"/>
      <mass value="0.100467493631956"/>
      <inertia ixx="3.42207960441524E-05" ixy="9.82554883966053E-09" ixz="-2.35749897825955E-07"
               iyy="3.47512781108353E-05" iyz="4.57302960893946E-09" izz="4.25510359877868E-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_dir}/lidar_front.STL"/>
      </geometry>
      <material name="home_base_lidar"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_dir}/lidar_front.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="lidar_front_joint" type="fixed">
    <origin xyz="0.287749512711774 -0.207249957761446 0.135795984178765" rpy="0 0 -1.5707963267949"/>
    <parent link="base_link"/>
    <child link="lidar_front"/>
  </joint>

  <!-- =================== lidar_rear =================== -->
  <link name="lidar_rear">
    <inertial>
      <origin xyz="-0.000159118177998907 3.36756577740127E-06 -0.00515345431268352" rpy="0 0 0"/>
      <mass value="0.100467493631956"/>
      <inertia ixx="3.42207960441524E-05" ixy="9.8255488396398E-09" ixz="-2.35749897825974E-07"
               iyy="3.47512781108353E-05" iyz="4.57302960896798E-09" izz="4.25510359877867E-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_dir}/lidar_rear.STL"/>
      </geometry>
      <material name="home_base_lidar"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_dir}/lidar_rear.STL"/>
      </geometry>
    </collision>
  </link>
  <joint name="lidar_rear_joint" type="fixed">
    <origin xyz="-0.287749512711767 0.207249947866326 0.135795984178765" rpy="0 0 1.5707963267949"/>
    <parent link="base_link"/>
    <child link="lidar_rear"/>
  </joint>

  <link name="xarm_base" />
  <joint name="xarm_joint" type="fixed">
    <origin xyz="0.0410000000000036 -0.00367166302995694 0.520695984178765" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="xarm_base" />
    <axis xyz="0 0 0" />
  </joint>


  <!-- =================== Conditionally add simulation components =================== -->
  <xacro:if value="${use_sim_time}">
    <xacro:home_base_ros2_control name="home_base" use_sim_time="${use_sim_time}"/>

    <!-- Webots driver plugin configuration -->
    <webots>
      <plugin type="webots_ros2_control::Ros2Control"/>
    </webots>
  </xacro:if>

</robot>
