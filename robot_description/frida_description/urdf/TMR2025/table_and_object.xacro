<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro" name="table_and_object">

  <!-- =====================================================================
       Standalone test fixture for manipulation sim:
         - static brown table centered 0.55 m in front of FRIDA's base_link
         - dynamic green 5 cm cube sitting on top of the table
       Both are independent of the house scene and easy to tweak.
       ===================================================================== -->

  <link name="world"/>

  <!-- ============ TABLE ============ -->
  <!-- 60 cm x 60 cm top, 70 cm tall, centered at (0.55, 0, 0.35).
       Mass only matters for inertia consistency — fixed joint makes it static. -->
  <link name="table_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.6 0.6 0.7"/>
      </geometry>
      <material name="table_wood">
        <color rgba="0.55 0.35 0.18 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.6 0.6 0.7"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="10.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.45" ixy="0" ixz="0" iyy="0.45" iyz="0" izz="0.6"/>
    </inertial>
  </link>

  <joint name="world_to_table" type="fixed">
    <parent link="world"/>
    <child link="table_link"/>
    <!-- 0.55 m forward of world origin. Table top at z = 0.35 + 0.35 = 0.7 m. -->
    <origin xyz="0.55 0 0.35" rpy="0 0 0"/>
  </joint>

  <!-- ============ CUBE (pickable) ============ -->
  <!-- 4x4 cm x 12 cm tall, 100 g, sitting on the table.
       Narrow enough (4 cm) for the custom gripper's ~5.6 cm opening.
       The 12 cm height keeps the collision volume small so MoveIt can
       plan grasp approaches reliably; feasibility is tuned to match via
       `pick_min_height:=0.05` on the sim's pick_and_place.launch.py.
       Floating joint -> MuJoCo free joint, so it falls/moves with
       physics. -->
  <link name="cube_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.04 0.12"/>
      </geometry>
      <material name="cube_green">
        <color rgba="0.2 0.8 0.2 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.04 0.12"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <!-- Cuboid inertia for 4 x 4 x 12 cm, 50 g.  Halved from the 100 g
           value because the sim's gripper hold force (~2-4 N effective
           with kp=200 at small contact error) couldn't resist the
           inertial spikes from arm retreats on a 100 g load; a 50 g mass
           keeps the behaviour realistic without requiring unphysical
           clamping force. -->
      <inertia ixx="6.7e-5" ixy="0" ixz="0" iyy="6.7e-5" iyz="0" izz="1.33e-5"/>
    </inertial>
  </link>

  <joint name="world_to_cube" type="floating">
    <parent link="world"/>
    <child link="cube_link"/>
    <!-- Start sitting on the table top (0.7 m) + half the cube height (0.06 m). -->
    <origin xyz="0.55 0 0.76" rpy="0 0 0"/>
  </joint>

  <!-- Match the gripper finger contact tuning for consistent behaviour
       (MuJoCo takes the softer/less-grippy of the two contacting geoms).
       Aggressive silicone-on-plastic friction (3/1/0.1) plus a firmer
       solref/solimp so the grasp doesn't bounce the cube out. -->
  <mujoco>
    <reference name="cube_link">
      <geom name="cube_link_collision_0" friction="5.0 2.0 0.2" solref="-50000 -500" solimp="0.98 0.999 0.0001" condim="4"/>
    </reference>

    <!-- Weld-on-attach was tested but leaves the cube welded at whatever
         offset it had when pick_server's attach signal fires (even with a
         settle delay), which visually and physically freezes the cube in
         a skewed orientation on the gripper.  Removed in favour of a pure
         physics grasp: tuned friction + MuJoCo solver options below.  The
         mujoco_ros2_control_plugin still subscribes to
         /attached_collision_object and looks for a "cube_to_eef" equality;
         without the declaration it simply logs DEBUG and does nothing, so
         no other code changes are needed. -->
  </mujoco>

</robot>
