<?xml version="1.0" encoding="UTF-8"?>
<!-- Top-level SRDF for FRIDA mounted on the omnibase mobile base
     (urdf/omnibase/robot.xacro, as assembled in urdf/TMR2025/FRIDA_Real.urdf.xacro).

     Use this instead of xarm.srdf.xacro whenever the omnibase URDF is loaded:
     it pulls in _xarm6_omnibase_macro.srdf.xacro, whose disable_collisions match
     the omnibase links (base_link chassis, wheel_FL/FR/RL/RR, lidar_front/rear)
     rather than the old base_link/LIDAR/laser/intel_realsense links. -->
<robot xmlns:xacro="http://wiki.ros.org/xacro" name="FRIDA">
  <!-- parameters -->
  <xacro:arg name="prefix" default="" />
  <!-- dof / robot_type are accepted for drop-in compatibility with the MoveIt
       config builder's SRDF mappings; the omnibase macro is xarm6-only. -->
  <xacro:arg name="dof" default="6" />
  <xacro:arg name="robot_type" default="xarm" />
  <xacro:arg name="add_gripper" default="false"/>
  <xacro:arg name="add_vacuum_gripper" default="false" />
  <xacro:arg name="add_bio_gripper" default="false" />
  <xacro:arg name="add_other_geometry" default="false" />

  <xacro:include filename="$(find frida_description)/srdf/_xarm6_omnibase_macro.srdf.xacro" />
  <xacro:xarm6_omnibase_macro_srdf prefix="$(arg prefix)"
    add_gripper="$(arg add_gripper)" add_vacuum_gripper="$(arg add_vacuum_gripper)"
    add_bio_gripper="$(arg add_bio_gripper)" add_other_geometry="$(arg add_other_geometry)" />

</robot>
