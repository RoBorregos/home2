# Ask the flat-grasp estimator for a single, stabilized grasp pose.
# The estimator collects several detection frames matching object_name,
# medians the grasp position and returns one stable pose. Replaces the old
# enable/disable + pose-topic streaming + client-side averaging flow.
string object_name
int32 num_samples       # frames to average; <= 0 uses the server default
---
geometry_msgs/PoseStamped pose
bool success
int32 samples_collected
string message
